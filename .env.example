# ============================================================
# CONFIGURACIÓN DEL ENTORNO - GLPI 11.0.6
# ============================================================
# Copia este archivo como .env y rellena los valores:
#   cp .env.example .env
#
# IMPORTANTE: Cambia TODAS las contraseñas antes de usar
#             en producción o en entornos compartidos.
# ============================================================

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=<contraseña-root-compleja>
MARIADB_DATABASE=glpidb
MARIADB_USER=glpi_user
MARIADB_PASSWORD=<contraseña-glpi-compleja>

# --- PhpMyAdmin ---
# Debe coincidir con MARIADB_ROOT_PASSWORD
PMA_USER=root
PMA_PASSWORD=<contraseña-root-compleja>
